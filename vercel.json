{
  "version": 2,
  "buildCommand": "pnpm install --frozen-lockfile=false && pnpm --filter @workspace/vireon run build",
  "outputDirectory": "artifacts/vireon/dist/public",
  "installCommand": "pnpm install --frozen-lockfile=false",
  "framework": null,
  "functions": {
    "api/index.ts": {
      "memory": 512,
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" }
  ]
}
